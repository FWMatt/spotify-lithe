#!/usr/bin/env python3
"""
spotify-lithe - a clean, dependency-free CLI for controlling Spotify Connect
devices (the Lithe speakers, or any Connect target) via the Spotify Web API.

This is the standalone companion to the Home Assistant `spotify_lithe`
integration: both drive playback the same way (single-call play with a
device id), via the shared `spotify_api` module. The CLI manages its own
OAuth (Authorization Code + PKCE, no client secret) and caches tokens per
account, so it works independently of Home Assistant.

Requires Spotify Premium and a free registered app for the client id
(https://developer.spotify.com — add redirect URI http://127.0.0.1:8888/callback).

  spotify-lithe login --client-id <id>        authorize (one-time, per account)
  spotify-lithe devices
  spotify-lithe playlists
  spotify-lithe play "<uri-or-share-url>" --device "Guest WC Speaker"
  spotify-lithe pause | resume | next | prev
  spotify-lithe vol 35 --device "Guest WC Speaker"
  spotify-lithe status --device "Guest WC Speaker"

Env: LITHE_SPOTIFY_CLIENT_ID, LITHE_SPOTIFY_DEVICE, LITHE_SPOTIFY_ACCOUNT.
"""

import argparse
import base64
import hashlib
import http.server
import json
import os
import secrets
import sys
import time
import urllib.error
import urllib.parse
import urllib.request
import webbrowser

import spotify_api

AUTH_URL = "https://accounts.spotify.com/authorize"
TOKEN_URL = "https://accounts.spotify.com/api/token"
SCOPES = "user-read-playback-state user-modify-playback-state playlist-read-private playlist-read-collaborative"
REDIRECT_PORT = 8888
REDIRECT_URI = "http://127.0.0.1:{}/callback".format(REDIRECT_PORT)


def _cfg_path(account):
    name = "spotify.json" if account == "default" else "spotify-{}.json".format(account)
    return os.path.expanduser("~/.config/lithe/" + name)


class Account:
    """OAuth + token cache for one Spotify account."""

    def __init__(self, account="default", client_id=None):
        self.path = _cfg_path(account)
        self.cfg = self._load()
        self.client_id = client_id or self.cfg.get("client_id")

    def _load(self):
        try:
            with open(self.path) as f:
                return json.load(f)
        except (OSError, ValueError):
            return {}

    def _save(self):
        os.makedirs(os.path.dirname(self.path), exist_ok=True)
        with open(self.path, "w") as f:
            json.dump(self.cfg, f, indent=2)
        try:
            os.chmod(self.path, 0o600)
        except OSError:
            pass

    # -- OAuth (PKCE) ------------------------------------------------------

    def login(self):
        if not self.client_id:
            raise spotify_api.SpotifyAPIError(
                "no client id. Create a free app at https://developer.spotify.com "
                "(redirect URI {}) and pass --client-id or set LITHE_SPOTIFY_CLIENT_ID.".format(
                    REDIRECT_URI
                )
            )
        verifier = base64.urlsafe_b64encode(secrets.token_bytes(64)).rstrip(b"=").decode()
        challenge = (
            base64.urlsafe_b64encode(hashlib.sha256(verifier.encode()).digest())
            .rstrip(b"=")
            .decode()
        )
        state = secrets.token_urlsafe(16)
        url = AUTH_URL + "?" + urllib.parse.urlencode(
            {
                "client_id": self.client_id,
                "response_type": "code",
                "redirect_uri": REDIRECT_URI,
                "scope": SCOPES,
                "code_challenge_method": "S256",
                "code_challenge": challenge,
                "state": state,
            }
        )
        result = {}

        class _Handler(http.server.BaseHTTPRequestHandler):
            def do_GET(self):
                parsed = urllib.parse.urlparse(self.path)
                if parsed.path != "/callback":
                    self.send_response(404)
                    self.end_headers()
                    return
                qs = urllib.parse.parse_qs(parsed.query)
                result["code"] = qs.get("code", [None])[0]
                result["state"] = qs.get("state", [None])[0]
                result["error"] = qs.get("error", [None])[0]
                self.send_response(200)
                self.send_header("Content-Type", "text/html")
                self.end_headers()
                self.wfile.write(b"<h2>spotify-lithe: authorized. You can close this tab.</h2>")

            def log_message(self, *a):
                pass

        try:
            httpd = http.server.HTTPServer(("127.0.0.1", REDIRECT_PORT), _Handler)
        except OSError as e:
            raise spotify_api.SpotifyAPIError("could not bind {}: {}".format(REDIRECT_URI, e))
        print("Opening browser to authorize Spotify...\n  " + url)
        try:
            webbrowser.open(url)
        except Exception:
            pass
        try:
            while not result:
                httpd.handle_request()
        finally:
            httpd.server_close()

        if result.get("error"):
            raise spotify_api.SpotifyAPIError("authorization denied: " + result["error"])
        if result.get("state") != state:
            raise spotify_api.SpotifyAPIError("state mismatch (possible CSRF); aborting")
        if not result.get("code"):
            raise spotify_api.SpotifyAPIError("no authorization code received")

        self._store(self._token_request({
            "grant_type": "authorization_code",
            "code": result["code"],
            "redirect_uri": REDIRECT_URI,
            "client_id": self.client_id,
            "code_verifier": verifier,
        }))
        print("Logged in. Tokens cached at " + self.path)

    def _token_request(self, fields):
        req = urllib.request.Request(
            TOKEN_URL,
            data=urllib.parse.urlencode(fields).encode(),
            headers={"Content-Type": "application/x-www-form-urlencoded"},
        )
        try:
            with urllib.request.urlopen(req, timeout=10) as r:
                return json.loads(r.read().decode())
        except urllib.error.HTTPError as e:
            raise spotify_api.SpotifyAPIError(
                "token request failed: {} {}".format(e.code, e.read().decode()[:200])
            )

    def _store(self, tok):
        self.cfg["access_token"] = tok["access_token"]
        self.cfg["expires_at"] = int(time.time()) + int(tok.get("expires_in", 3600)) - 30
        if tok.get("refresh_token"):
            self.cfg["refresh_token"] = tok["refresh_token"]
        self.cfg["client_id"] = self.client_id
        self._save()

    def token(self):
        if not self.cfg.get("access_token"):
            raise spotify_api.SpotifyAPIError("not logged in; run 'spotify-lithe login'")
        if time.time() >= self.cfg.get("expires_at", 0):
            rt = self.cfg.get("refresh_token")
            if not rt:
                raise spotify_api.SpotifyAPIError("not logged in; run 'spotify-lithe login'")
            self._store(self._token_request({
                "grant_type": "refresh_token",
                "refresh_token": rt,
                "client_id": self.client_id,
            }))
        return self.cfg["access_token"]


def main(argv=None):
    # Shared options on a parent parser so they work AFTER the subcommand
    # (e.g. `play <uri> --device "Guest WC Speaker"`).
    common = argparse.ArgumentParser(add_help=False)
    common.add_argument("--client-id", default=os.environ.get("LITHE_SPOTIFY_CLIENT_ID"))
    common.add_argument("--account", default=os.environ.get("LITHE_SPOTIFY_ACCOUNT", "default"),
                        help="Token profile name (default 'default').")
    common.add_argument("--device", default=os.environ.get("LITHE_SPOTIFY_DEVICE"),
                        help="Target Connect device (substring match); default = active device.")

    parser = argparse.ArgumentParser(prog="spotify-lithe", description=__doc__.splitlines()[1])
    sub = parser.add_subparsers(dest="cmd", required=True)
    sub.add_parser("login", parents=[common])
    sub.add_parser("devices", parents=[common])
    sub.add_parser("playlists", parents=[common])
    p_play = sub.add_parser("play", parents=[common])
    p_play.add_argument("uri", nargs="?")
    for c in ("pause", "resume", "next", "prev", "status"):
        sub.add_parser(c, parents=[common])
    p_vol = sub.add_parser("vol", parents=[common])
    p_vol.add_argument("level", type=int)

    args = parser.parse_args(argv)
    acct = Account(account=args.account, client_id=args.client_id)

    try:
        if args.cmd == "login":
            acct.login()
            return 0

        token = acct.token()
        device_id = spotify_api.find_device_id(token, args.device) if args.device else None

        if args.cmd == "devices":
            for d in spotify_api.devices(token):
                print("{:<28} {:<11} vol={:<4} {}".format(
                    d.get("name"), d.get("type"), d.get("volume_percent"),
                    "ACTIVE" if d.get("is_active") else "").rstrip())
        elif args.cmd == "playlists":
            for p in spotify_api.playlists(token):
                print("{:<40} {}".format((p["name"] or "")[:40], p["uri"]))
        elif args.cmd == "play":
            uri = spotify_api.normalize_uri(args.uri) if args.uri else None
            spotify_api.play(token, device_id=device_id, context_uri=uri)
            print("playing" + (" on " + args.device if args.device else ""))
        elif args.cmd == "pause":
            spotify_api.pause(token, device_id); print("paused")
        elif args.cmd == "resume":
            spotify_api.play(token, device_id=device_id); print("resumed")
        elif args.cmd == "next":
            spotify_api.next_track(token, device_id); print("next")
        elif args.cmd == "prev":
            spotify_api.previous_track(token, device_id); print("prev")
        elif args.cmd == "vol":
            spotify_api.set_volume(token, args.level, device_id); print("vol {}".format(args.level))
        elif args.cmd == "status":
            if args.device:
                devs = spotify_api.devices(token)
                match = next((d for d in devs if args.device.lower() in (d.get("name") or "").lower()), None)
                if not match:
                    print("device {!r} not online. Available: {}".format(
                        args.device, [d.get("name") for d in devs] or "(none)"))
                    return 1
                if not match.get("is_active"):
                    active = next((d.get("name") for d in devs if d.get("is_active")), None)
                    print(json.dumps({"device": match.get("name"), "is_active": False,
                                      "volume": match.get("volume_percent"), "active_device": active}, indent=2))
                    return 0
            pb = spotify_api.current_playback(token)
            if not pb:
                print("no active playback"); return 0
            item = pb.get("item") or {}
            dev = pb.get("device") or {}
            print(json.dumps({
                "device": dev.get("name"),
                "is_playing": pb.get("is_playing"),
                "track": item.get("name"),
                "artists": ", ".join(a["name"] for a in item.get("artists", [])),
                "volume": dev.get("volume_percent"),
            }, indent=2))
    except spotify_api.SpotifyAPIError as e:
        print("error: {}".format(e), file=sys.stderr)
        return 2
    return 0


if __name__ == "__main__":
    sys.exit(main())
